# Labus Sales RAG — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Deepseek API (LLM)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qdrant (vector store) — use http://qdrant:6333 in Docker
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=labus_docs

# Model paths (relative to project root)
EMBEDDING_MODEL_PATH=models/embeddings/BAAI_bge-m3
RERANKER_MODEL_PATH=models/reranker/BAAI_bge-reranker-v2-m3

# Data directories
DATA_DIR=data
INDEX_DIR=indexes
LOG_DIR=logs
LOG_LEVEL=INFO

# Vision API (image analysis — Artemox/Gemini)
VISION_API_KEY=sk-your-vision-api-key
VISION_BASE_URL=https://api.artemox.com/v1
VISION_MODEL=gemini-2.0-flash

# Retrieval params
RETRIEVAL_TOP_K=20
RERANK_TOP_N=8
RRF_ALPHA=0.7

# Auth — CHANGE THIS! Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-random-secret
